{
  "name": "avia-calendar-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode mock",
    "dev:mock": "vite --mode mock",
    "dev:api": "vite --mode api",
    "build": "tsc -b && vite build",
    "build:mock": "tsc -b && vite build --mode mock",
    "build:api": "tsc -b && vite build --mode api",
    "preview": "vite preview",
    "preview:mock": "npm run build:mock && vite preview",
    "preview:api": "npm run build:api && vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "format:check": "prettier . --ignore-path .prettierignore --check",
    "format:fix": "prettier . --ignore-path .prettierignore --write",
    "prepare": "cd .. && husky frontend/.husky"
  },
  "dependencies": {
    "@ant-design/icons": "6.2.3",
    "antd": "6.4.0",
    "clsx": "2.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "msw": "2.13.6",
    "prettier": "3.8.3",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.4",
    "vite-plugin-svgr": "5.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
