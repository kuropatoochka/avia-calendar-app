# Скопируйте в .env и подставьте свои значения.
# Docker Compose подставляет эти переменные из .env в docker-compose.yml (см. ${VAR}).
# Сервис api дополнительно получает весь файл через env_file (опционально).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tickets
# Порт PostgreSQL на хосте (сервис db). Внутри сети compose БД доступна как хост `db`.
POSTGRES_PORT=5432

# Локальный uvicorn: хост localhost.
# Docker Compose: либо укажите хост БД как `db`, либо закомментируйте строку —
# тогда compose подставит резервный URL на сервис `db` (см. docker-compose.yml).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tickets
